# Template only: do not copy these placeholder secrets into a running system.
# Prefer ./manage.sh init, which generates random values and applies mode 0600.
PAOPAO_BIND_ADDRESS=127.0.0.1
PAOPAO_PORT=8008
PAOPAO_PUBLIC_HOST=localhost:8008
PAOPAO_PUBLIC_SECURE=false
PAOPAO_JWT_SECRET=replace-with-at-least-32-random-characters
PAOPAO_ADMIN_SETTINGS_KEY=replace-with-at-least-32-random-characters
PAOPAO_MEILI_MASTER_KEY=replace-with-at-least-32-random-characters
PAOPAO_MYSQL_PASSWORD=replace-with-a-random-password-for-standard-mode
PAOPAO_MYSQL_ROOT_PASSWORD=replace-with-a-separate-random-root-password

# Optional image/version overrides.
PAOPAO_IMAGE=paopao-ce:local
REDIS_TAG=7.2-alpine
MEILI_TAG=v1.49.0
MYSQL_TAG=8.0
